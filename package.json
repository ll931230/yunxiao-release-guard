{
  "name": "yunxiao-release-guard",
  "version": "0.2.0",
  "description": "Guard Yunxiao releases by checking that the current branch contains the latest base branch.",
  "type": "module",
  "bin": {
    "yunxiao-release-guard": "bin/yunxiao-release-guard.mjs"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "scripts": {
    "check": "node --check bin/yunxiao-release-guard.mjs && node --test",
    "test": "node --test"
  },
  "keywords": [
    "yunxiao",
    "release",
    "ci",
    "git",
    "branch-guard"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
